# =============================================================
# HW MAIN PORTAL — Variables de entorno
# =============================================================
# Copia este archivo a `.env.local` y rellena con valores reales.
# Nunca commitees `.env.local` — está en .gitignore.
# =============================================================

# -------------------------------------------------------------
# Aplicación
# -------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# -------------------------------------------------------------
# Supabase del propio portal (schema `portal`)
# Crear nuevo proyecto en https://supabase.com/dashboard
# -------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://thkrkubkiasfqmiiwfbj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# Runtime — Transaction pooler (6543) con role portal_app sin DDL.
# Es lo que usa el código del portal en dev y prod para todas las queries.
PORTAL_DATABASE_URL=postgresql://portal_app.thkrkubkiasfqmiiwfbj:PASSWORD@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?sslmode=require

# DDL — Session pooler (5432) con role postgres. Solo para migraciones.
# Solo lo lee drizzle-kit y scripts/apply-migration.mjs.
PORTAL_DATABASE_DDL_URL=postgresql://postgres.thkrkubkiasfqmiiwfbj:POSTGRES_PASSWORD@aws-0-eu-west-3.pooler.supabase.com:5432/postgres?sslmode=require

# Token para el MCP de Supabase del portal
SUPABASE_PORTAL_ACCESS_TOKEN=sbp_...

# -------------------------------------------------------------
# Supabase de MainOPS (lectura)
# Project: gbuifpsgcvxmuwzoyush
# -------------------------------------------------------------
MAINOPS_API_BASE_URL=https://hw-sell-gear-platform-tsm1.vercel.app
MAINOPS_API_TOKEN=

# Token para el MCP de Supabase de MainOPS
SUPABASE_MAINOPS_ACCESS_TOKEN=sbp_...

# -------------------------------------------------------------
# Connector HW Tool (analytics-api edge function)
# Project: olcxbtvjkjmofrbvzpat
# Edge function expone GET con header `x-api-key`. Endpoints:
#   ?endpoint=health → ping
#   ?endpoint=schema → contrato auto-documentado
#   ?from=YYYY-MM-DD&to=YYYY-MM-DD&technician=NAME → métricas
# -------------------------------------------------------------
HWTOOL_ANALYTICS_API_URL=https://olcxbtvjkjmofrbvzpat.supabase.co/functions/v1/analytics-api
HWTOOL_ANALYTICS_API_KEY=

# Token para el MCP de Supabase de HW Tool (opcional, para inspección)
SUPABASE_HWTOOL_ACCESS_TOKEN=sbp_...

# -------------------------------------------------------------
# Auth — Magic Link
# -------------------------------------------------------------
# Lista de admins separados por coma (override del rol por dominio)
PORTAL_ADMIN_EMAILS=jj.gallego@qamarero.com,guillermo.mateos@qamarero.com,domingo.bueno@qamarero.com

# Allowlist por dominio (regex). Solo correos que matcheen pueden registrarse.
PORTAL_EMAIL_ALLOWLIST_DOMAIN=qamarero.com

# -------------------------------------------------------------
# GitHub (para MCP github)
# -------------------------------------------------------------
GITHUB_TOKEN=ghp_...

# -------------------------------------------------------------
# Figma (para MCP figma) — opcional
# -------------------------------------------------------------
FIGMA_API_KEY=

# -------------------------------------------------------------
# Observabilidad (opcional, v2)
# -------------------------------------------------------------
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
