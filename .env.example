# =============================================================
# HW MAIN PORTAL — Variables de entorno
# =============================================================
# Copia este archivo a `.env.local` y rellena con valores reales.
# Nunca commitees `.env.local` — está en .gitignore.
# =============================================================

# -------------------------------------------------------------
# Aplicación
# -------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# -------------------------------------------------------------
# Supabase del propio portal (schema `portal`)
# Crear nuevo proyecto en https://supabase.com/dashboard
# -------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://thkrkubkiasfqmiiwfbj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# Runtime — Transaction pooler (6543) con role portal_app sin DDL.
# Es lo que usa el código del portal en dev y prod para todas las queries.
PORTAL_DATABASE_URL=postgresql://portal_app.thkrkubkiasfqmiiwfbj:PASSWORD@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?sslmode=require

# DDL — Session pooler (5432) con role postgres. Solo para migraciones.
# Solo lo lee drizzle-kit y scripts/apply-migration.mjs.
PORTAL_DATABASE_DDL_URL=postgresql://postgres.thkrkubkiasfqmiiwfbj:POSTGRES_PASSWORD@aws-0-eu-west-3.pooler.supabase.com:5432/postgres?sslmode=require

# Token para el MCP de Supabase del portal
SUPABASE_PORTAL_ACCESS_TOKEN=sbp_...

# -------------------------------------------------------------
# Connector MainOps (endpoint /api/external/metrics)
# Repo: qamarero/hw-SellGear-platform
# El endpoint expone GET con header `X-API-Key`. Auth en MAINOPS_API_KEY,
# que debe coincidir con MAIN_PORTAL_API_KEY en MainOps. Generar con
# `openssl rand -hex 32` y compartir con el admin de MainOps.
# -------------------------------------------------------------
MAINOPS_BASE_URL=https://hw-sell-gear-platform.vercel.app
MAINOPS_API_KEY=

# Token para el MCP de Supabase de MainOPS (opcional, solo inspección)
SUPABASE_MAINOPS_ACCESS_TOKEN=sbp_...

# -------------------------------------------------------------
# Connector HW Tool (analytics-api edge function)
# Project: olcxbtvjkjmofrbvzpat
# Edge function expone GET con header `x-api-key`. Endpoints:
#   ?endpoint=health → ping
#   ?endpoint=schema → contrato auto-documentado
#   ?from=YYYY-MM-DD&to=YYYY-MM-DD&technician=NAME → métricas
# -------------------------------------------------------------
HWTOOL_ANALYTICS_API_URL=https://olcxbtvjkjmofrbvzpat.supabase.co/functions/v1/analytics-api
HWTOOL_ANALYTICS_API_KEY=

# Token para el MCP de Supabase de HW Tool (opcional, para inspección)
SUPABASE_HWTOOL_ACCESS_TOKEN=sbp_...

# -------------------------------------------------------------
# Connector HSM (Hardware Support Manager)
# Repo: qamarero/Hardware-Support-Manager-main
# El endpoint /api/external/metrics aún no está implementado en HSM —
# spec en docs/connectors/hsm-endpoint-spec.md. Mientras estas vars
# estén vacías, el banner muestra "Conectando con HSM…" y la home
# sigue funcionando. Cuando el endpoint exista:
#   1. Configurar HSM_BASE_URL al deploy de Vercel del HSM.
#   2. Configurar HSM_API_KEY con el mismo valor que MAIN_PORTAL_API_KEY
#      en HSM (generar con `openssl rand -hex 32` y compartir).
#   3. Redeploy del portal en Vercel para que tome las env vars.
# -------------------------------------------------------------
HSM_BASE_URL=
HSM_API_KEY=

# -------------------------------------------------------------
# Auth — Magic Link
# -------------------------------------------------------------
# Lista de emails admin separados por coma. SIEMPRE usados como allowlist
# del HTTP Basic Auth de /admin/* (independiente de PORTAL_AUTH_BYPASS).
# Si el portal vuelve a Supabase Auth, también define el rol "admin".
PORTAL_ADMIN_EMAILS=jj.gallego@qamarero.com,domingo.bueno@qamarero.com

# Password compartida para el HTTP Basic Auth de /admin/*.
# El portal está abierto para consulta pero las páginas admin requieren
# email + password (Basic Auth, prompt nativo del navegador).
# Generar con `openssl rand -hex 16` para producción, rotar cuando un
# admin cambia. Si no se configura, /admin/* devuelve 503 explícito.
PORTAL_ADMIN_PASSWORD=

# Allowlist por dominio (regex). Solo correos que matcheen pueden registrarse.
PORTAL_EMAIL_ALLOWLIST_DOMAIN=qamarero.com

# Bypass de auth (entorno cerrado). Si "true", el portal salta el login
# y carga al primer email de PORTAL_ADMIN_EMAILS como admin sintético.
# El topbar muestra un banner amarillo claramente visible.
# Solo dejar activo cuando el portal NO sea accesible al exterior.
PORTAL_AUTH_BYPASS=false

# -------------------------------------------------------------
# GitHub (para MCP github)
# -------------------------------------------------------------
GITHUB_TOKEN=ghp_...

# -------------------------------------------------------------
# Figma (para MCP figma) — opcional
# -------------------------------------------------------------
FIGMA_API_KEY=

# -------------------------------------------------------------
# Observabilidad (opcional, v2)
# -------------------------------------------------------------
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
